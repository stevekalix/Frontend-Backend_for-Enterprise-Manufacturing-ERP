projection implementation in class zbp_i_product_m unique;
strict ( 2 );

define behavior for ZI_PRODUCT_M alias Product
{
  use create;
  use update;
  use delete;

  use association _BOM { create; }
}

define behavior for ZI_BOM_M alias BOM
{
  use update;
  use delete;

  use association _Product;
}