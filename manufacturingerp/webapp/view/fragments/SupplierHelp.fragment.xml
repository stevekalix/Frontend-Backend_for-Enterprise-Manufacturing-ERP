<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        title="Select Supplier"
        items="{/Supplier}"
        search=".onSupplierValueHelpSearch"
        confirm=".onSupplierValueHelpConfirm"
        cancel=".onSupplierValueHelpCancel">
        <StandardListItem
            title="{SupplierId}"
            description="{SupplierName}"
            info="{Status}"
            type="Active" />
    </SelectDialog>
</core:FragmentDefinition>
