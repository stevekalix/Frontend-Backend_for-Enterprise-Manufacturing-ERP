<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Dialog id="productDialog" title="{dialog>/title}">
        <content>
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">
                <form:content>
                    <!-- Product ID: Editable only on Create -->
                    <Label text="Product ID" required="true" />
                    <Input id="inputProductId"
                        value="{dialog>/ProductId}"
                        placeholder="e.g. PROD_001"
                        maxLength="10"
                        editable="{dialog>/isCreate}" />

                    <Label text="Product Name" required="true" />
                    <Input id="inputProductName"
                        value="{dialog>/ProductName}"
                        placeholder="Enter product name"
                        maxLength="50" />

                    <Label text="Category" required="true" />
                    <Input id="inputCategory"
                        value="{dialog>/Category}"
                        placeholder="Select category"
                        showValueHelp="true"
                        valueHelpRequest=".onCategoryValueHelpRequest" />

                    <Label text="Profit Percentage (%)" required="true" />
                    <Input id="inputProfitPercentage"
                        value="{dialog>/ProfitPercentage}"
                        type="Number"
                        placeholder="e.g. 15.00" />

                    <Label text="Currency" required="true" />
                    <Input id="inputCurrency"
                        value="{dialog>/Currency}"
                        placeholder="Select currency"
                        showValueHelp="true"
                        valueHelpRequest=".onCurrencyValueHelpRequest" />

                    <Label text="Status" required="true" />
                    <Select id="selectStatus" selectedKey="{dialog>/Status}">
                        <core:Item key="Active" text="Active" />
                        <core:Item key="Inactive" text="Inactive" />
                    </Select>
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press=".onSaveProduct" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelProduct" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
