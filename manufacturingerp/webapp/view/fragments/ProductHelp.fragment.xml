<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        title="Select Product"
        items="{/Product}"
        search=".onProductValueHelpSearch"
        confirm=".onProductValueHelpConfirm"
        cancel=".onProductValueHelpCancel">
        <StandardListItem
            title="{ProductId}"
            description="{ProductName}"
            info="{Status}"
            type="Active" />
    </SelectDialog>
</core:FragmentDefinition>
