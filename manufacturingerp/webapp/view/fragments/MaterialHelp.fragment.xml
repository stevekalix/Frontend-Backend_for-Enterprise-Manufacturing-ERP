<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        title="Select Raw Material"
        items="{/Material}"
        search=".onMaterialValueHelpSearch"
        confirm=".onMaterialValueHelpConfirm"
        cancel=".onMaterialValueHelpCancel">
        <StandardListItem
            title="{MaterialId}"
            description="{MaterialName}"
            info="{UnitPrice} {CukyField}"
            type="Active" />
    </SelectDialog>
</core:FragmentDefinition>
