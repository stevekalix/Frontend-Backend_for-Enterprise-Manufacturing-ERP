<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Dialog id="supplierDialog" title="{dialog>/title}">
        <content>
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">
                <form:content>
                    <Label text="Supplier ID" required="true" />
                    <Input id="inputSupplierId"
                        value="{dialog>/SupplierId}"
                        placeholder="e.g. SPL_001"
                        maxLength="10"
                        editable="{dialog>/isCreate}" />

                    <Label text="Supplier Name" required="true" />
                    <Input id="inputSupplierName"
                        value="{dialog>/SupplierName}"
                        placeholder="Enter supplier name"
                        maxLength="50" />

                    <Label text="GST Number" required="true" />
                    <Input id="inputGstNumber"
                        value="{dialog>/GstNumber}"
                        placeholder="Enter 15-digit GST number"
                        maxLength="15" />

                    <Label text="Phone" />
                    <Input id="inputPhone"
                        value="{dialog>/Phone}"
                        placeholder="Enter phone number"
                        maxLength="15" />

                    <Label text="Email" />
                    <Input id="inputEmail"
                        value="{dialog>/Email}"
                        placeholder="Enter email address"
                        type="Email"
                        maxLength="50" />

                    <Label text="Address" />
                    <TextArea id="inputAddress"
                        value="{dialog>/Address}"
                        placeholder="Enter address"
                        rows="3"
                        maxLength="100" />

                    <Label text="Status" required="true" />
                    <Select id="selectStatus" selectedKey="{dialog>/Status}">
                        <core:Item key="Active" text="Active" />
                        <core:Item key="Inactive" text="Inactive" />
                    </Select>
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press=".onSaveSupplier" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelSupplier" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
