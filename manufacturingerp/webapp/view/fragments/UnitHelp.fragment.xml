<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        title="Select Unit of Measure"
        items="{/I_UnitOfMeasure}"
        search=".onUnitValueHelpSearch"
        confirm=".onUnitValueHelpConfirm"
        cancel=".onUnitValueHelpCancel">
        <StandardListItem
            title="{UnitOfMeasure}"
            description="{UnitOfMeasure_Text}"
            type="Active" />
    </SelectDialog>
</core:FragmentDefinition>
