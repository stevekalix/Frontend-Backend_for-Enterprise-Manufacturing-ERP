<mvc:View controllerName="com.manufacturing.erp.manufacturingerp.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m">
    <tnt:ToolPage id="toolPage" sideExpanded="true">
        <tnt:header>
            <tnt:ToolHeader>
                <Button id="sideNavigationToggleButton"
                    icon="sap-icon://menu"
                    type="Transparent"
                    press=".onSideNavButtonPress"
                    tooltip="Toggle Navigation" />
                <Image src="https://www.sap.com/dam/application/shared/logos/sap-logo-svg.svg" height="24px" class="sapUiSmallMarginBegin" />
                <Title text="Enterprise Manufacturing ERP System" level="H1" class="sapUiSmallMarginBegin" />
                <ToolbarSpacer />
                <Button icon="sap-icon://bell" type="Transparent" press=".onNotificationPress" tooltip="Notifications" />
                <Button icon="sap-icon://customer" text="Manikandan" type="Transparent" press=".onProfilePress" tooltip="Profile" />
                <Button icon="sap-icon://log" type="Transparent" press=".onLogoutPress" tooltip="Logout" />
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNavigation" selectedKey="dashboard" itemSelect=".onSideNavItemSelect">
                <tnt:NavigationList>
                    <tnt:NavigationListItem text="Dashboard" icon="sap-icon://home" key="dashboard" />
                    <tnt:NavigationListItem text="Product" icon="sap-icon://product" key="product" />
                    <tnt:NavigationListItem text="Bill of Materials" icon="sap-icon://clinical-tasty-recipe" key="bom" />
                    <tnt:NavigationListItem text="Supplier" icon="sap-icon://shipping-status" key="supplier" />
                    <tnt:NavigationListItem text="Raw Material" icon="sap-icon://factory" key="material" />
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <App id="app" />
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>