<mvc:View controllerName="com.manufacturing.erp.manufacturingerp.controller.BOM"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m">
    <f:DynamicPage id="bomPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Bill of Materials (BOM)" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <VBox class="sapUiContentPadding">
                <Table id="bomTable"
                    items="{path: '/BOM', parameters: {$count: true}}"
                    mode="SingleSelectLeft"
                    growing="true"
                    growingThreshold="10"
                    class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="BOM Records" />
                            <ToolbarSpacer />
                            <SearchField id="searchField" width="30%" placeholder="Search BOM by Product ID..." search=".onSearch" />
                            <Button icon="sap-icon://add" text="Create" type="Transparent" press=".onCreate" tooltip="Create new BOM" />
                            <Button icon="sap-icon://edit" text="Edit" type="Transparent" press=".onEdit" tooltip="Edit selected BOM" />
                            <Button icon="sap-icon://delete" text="Delete" type="Negative" press=".onDelete" tooltip="Delete selected BOM" />
                            <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh" tooltip="Refresh data" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="8rem">
                            <Text text="BOM ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Product ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Material ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Material Name" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="End">
                            <Text text="Quantity" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                            <Text text="Unit" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="End">
                            <Text text="Unit Price" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="Total Amount" />
                        </Column>
                        <Column width="5rem" hAlign="Center">
                            <Text text="Currency" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{BomId}" />
                                <Text text="{ProductId}" />
                                <Text text="{MaterialId}" />
                                <Text text="{MaterialName}" />
                                <Text text="{parts: [{path: 'Quantity'}], formatter: '.formatter.formatNumber'}" />
                                <Text text="{Unit}" />
                                <Text text="{parts: [{path: 'UnitPrice'}, {path: 'Currency'}], formatter: '.formatter.formatCurrency'}" />
                                <Text text="{parts: [{path: 'TotalAmount'}, {path: 'Currency'}], formatter: '.formatter.formatCurrency'}" />
                                <Text text="{Currency}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
