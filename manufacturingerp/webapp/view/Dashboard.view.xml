<mvc:View controllerName="com.manufacturing.erp.manufacturingerp.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns="sap.m">
    <f:DynamicPage id="dashboardPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Dashboard" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <VBox>
                <layout:Grid containerQuery="true" defaultSpan="XL3 L4 M6 S12" class="sapUiSmallMargin">
                    
                    <!-- Product Card -->
                    <f:Card class="dashboardCard sapUiSmallMarginBottom">
                        <f:header>
                            <card:Header title="Products" subtitle="Active catalog items" iconSrc="sap-icon://product" />
                        </f:header>
                        <f:content>
                            <VBox class="sapUiContentPadding" alignItems="Center" justifyContent="Center">
                                <HBox class="cardIconBox sapUiSmallMarginBottom" alignItems="Center" justifyContent="Center">
                                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://product" size="2rem" color="#2563eb" />
                                </HBox>
                                <Text text="{dashboard>/productsCount}" class="cardCountText" />
                                <Button text="Manage Products" type="Emphasized" press=".onNavigateToProducts" class="sapUiSmallMarginTop fullWidth" icon="sap-icon://navigation-right-arrow" iconFirst="false" />
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- Supplier Card -->
                    <f:Card class="dashboardCard sapUiSmallMarginBottom">
                        <f:header>
                            <card:Header title="Suppliers" subtitle="Registered suppliers" iconSrc="sap-icon://shipping-status" />
                        </f:header>
                        <f:content>
                            <VBox class="sapUiContentPadding" alignItems="Center" justifyContent="Center">
                                <HBox class="cardIconBox sapUiSmallMarginBottom" alignItems="Center" justifyContent="Center">
                                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://shipping-status" size="2rem" color="#2563eb" />
                                </HBox>
                                <Text text="{dashboard>/suppliersCount}" class="cardCountText" />
                                <Button text="Manage Suppliers" type="Emphasized" press=".onNavigateToSuppliers" class="sapUiSmallMarginTop fullWidth" icon="sap-icon://navigation-right-arrow" iconFirst="false" />
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- Material Card -->
                    <f:Card class="dashboardCard sapUiSmallMarginBottom">
                        <f:header>
                            <card:Header title="Raw Materials" subtitle="Inventory & stock levels" iconSrc="sap-icon://factory" />
                        </f:header>
                        <f:content>
                            <VBox class="sapUiContentPadding" alignItems="Center" justifyContent="Center">
                                <HBox class="cardIconBox sapUiSmallMarginBottom" alignItems="Center" justifyContent="Center">
                                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://factory" size="2rem" color="#2563eb" />
                                </HBox>
                                <Text text="{dashboard>/materialsCount}" class="cardCountText" />
                                <Button text="Manage Materials" type="Emphasized" press=".onNavigateToMaterials" class="sapUiSmallMarginTop fullWidth" icon="sap-icon://navigation-right-arrow" iconFirst="false" />
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- BOM Card -->
                    <f:Card class="dashboardCard sapUiSmallMarginBottom">
                        <f:header>
                            <card:Header title="Bill of Materials" subtitle="Product structures" iconSrc="sap-icon://clinical-tasty-recipe" />
                        </f:header>
                        <f:content>
                            <VBox class="sapUiContentPadding" alignItems="Center" justifyContent="Center">
                                <HBox class="cardIconBox sapUiSmallMarginBottom" alignItems="Center" justifyContent="Center">
                                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://clinical-tasty-recipe" size="2rem" color="#2563eb" />
                                </HBox>
                                <Text text="{dashboard>/bomsCount}" class="cardCountText" />
                                <Button text="Manage BOMs" type="Emphasized" press=".onNavigateToBoms" class="sapUiSmallMarginTop fullWidth" icon="sap-icon://navigation-right-arrow" iconFirst="false" />
                            </VBox>
                        </f:content>
                    </f:Card>

                </layout:Grid>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
