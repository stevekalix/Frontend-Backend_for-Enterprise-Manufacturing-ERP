<mvc:View controllerName="com.manufacturing.erp.manufacturingerp.controller.Material"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m">
    <f:DynamicPage id="materialPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Raw Materials" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <VBox class="sapUiContentPadding">
                <Table id="materialTable"
                    items="{path: '/Material', parameters: {$count: true}}"
                    mode="SingleSelectLeft"
                    growing="true"
                    growingThreshold="10"
                    class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Raw Material Inventory" />
                            <ToolbarSpacer />
                            <SearchField id="searchField" width="30%" placeholder="Search materials..." search=".onSearch" />
                            <Button icon="sap-icon://add" text="Create" type="Transparent" press=".onCreate" tooltip="Create new material" />
                            <Button icon="sap-icon://edit" text="Edit" type="Transparent" press=".onEdit" tooltip="Edit selected material" />
                            <Button icon="sap-icon://delete" text="Delete" type="Negative" press=".onDelete" tooltip="Delete selected material" />
                            <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh" tooltip="Refresh data" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="8rem">
                            <Text text="Material ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Material Name" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Supplier ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Category" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                            <Text text="Unit" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="End">
                            <Text text="Unit Price" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                            <Text text="Currency" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="Current Stock" />
                        </Column>
                        <Column width="7rem" hAlign="Center">
                            <Text text="Status" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{MaterialId}" />
                                <Text text="{MaterialName}" />
                                <Text text="{SupplierId}" />
                                <Text text="{Category}" />
                                <Text text="{Unit}" />
                                <Text text="{parts: [{path: 'UnitPrice'}, {path: 'CukyField'}], formatter: '.formatter.formatCurrency'}" />
                                <Text text="{CukyField}" />
                                <Text text="{parts: [{path: 'CurrentStock'}], formatter: '.formatter.formatNumber'} {Unit}" />
                                <ObjectStatus text="{Status}" state="{path: 'Status', formatter: '.formatter.statusState'}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
