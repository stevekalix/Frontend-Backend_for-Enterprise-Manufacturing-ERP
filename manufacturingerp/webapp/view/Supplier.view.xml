<mvc:View controllerName="com.manufacturing.erp.manufacturingerp.controller.Supplier"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m">
    <f:DynamicPage id="supplierPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Suppliers" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <VBox class="sapUiContentPadding">
                <Table id="supplierTable"
                    items="{/Supplier}"
                    mode="SingleSelectLeft"
                    growing="true"
                    growingThreshold="10"
                    class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Supplier List" />
                            <ToolbarSpacer />
                            <SearchField id="searchField" width="30%" placeholder="Search suppliers..." search=".onSearch" />
                            <Button icon="sap-icon://add" text="Create" type="Transparent" press=".onCreate" tooltip="Create new supplier" />
                            <Button icon="sap-icon://edit" text="Edit" type="Transparent" press=".onEdit" tooltip="Edit selected supplier" />
                            <Button icon="sap-icon://delete" text="Delete" type="Negative" press=".onDelete" tooltip="Delete selected supplier" />
                            <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh" tooltip="Refresh data" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="8rem">
                            <Text text="Supplier ID" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Supplier Name" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="GST Number" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true">
                            <Text text="Phone" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true">
                            <Text text="Email" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true">
                            <Text text="Address" />
                        </Column>
                        <Column width="7rem" hAlign="Center">
                            <Text text="Status" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{SupplierId}" />
                                <Text text="{SupplierName}" />
                                <Text text="{GstNumber}" />
                                <Text text="{Phone}" />
                                <Text text="{Email}" />
                                <Text text="{Address}" />
                                <ObjectStatus text="{Status}" state="{path: 'Status', formatter: '.formatter.statusState'}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
