{
  "_version": "1.83.1",
  "sap.app": {
    "id": "com.manufacturing.erp.manufacturingerp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.28.0",
      "toolsId": "74334599-98cb-450d-83bb-36d14847cad5"
    },
    "dataSources": {
      "ZUI_MANUFACTURING_VAN": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='ZUI_MANUFACTURING_VAN',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/ZUI_MANUFACTURING_VAN.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZUI_MANUFACTURING/",
        "type": "OData",
        "settings": {
          "annotations": [
            "ZUI_MANUFACTURING_VAN"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.3",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.manufacturing.erp.manufacturingerp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.manufacturing.erp.manufacturingerp.view",
        "async": true,
        "viewPath": "com.manufacturing.erp.manufacturingerp.view"
      },
      "routes": [
        {
          "name": "RouteManufacturing_ERP_System",
          "pattern": ":?query:",
          "target": [
            "TargetManufacturing_ERP_System"
          ]
        }
      ],
      "targets": {
        "TargetManufacturing_ERP_System": {
          "id": "Manufacturing_ERP_System",
          "name": "Manufacturing_ERP_System"
        }
      }
    },
    "rootView": {
      "viewName": "com.manufacturing.erp.manufacturingerp.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
